# Copy to .env and fill in. Never commit the real .env.

# OpenAI — used by the audit agents + the structuring/synthesis calls
OPENAI_API_KEY=

# Redis Cloud — stores the deep-scanned page facts (discrete vars avoid URL-encoding issues)
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=default
REDIS_PASSWORD=

# GitHub PAT (classic, 'repo' scope) — for the auto-fix branch push + PR
GITHUB_TOKEN=

# Optional: only needed if you switch the LLM back to Groq in agent.py
GROQ_API_KEY=
